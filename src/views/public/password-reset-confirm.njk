{# Password reset confirm form (task 11.2).
   Validates: Requirements 3.8, 3.10 (Design §8.2).

   Inputs:
     - locale       : 'id' | 'en'
     - token        : string  (43-char base64url; sticks back into the form action)
     - errors       : Record<string, string[]>  (zod fieldErrors)
     - generalError : string | null
     - cspNonce     : string
#}
{% extends "layouts/public.njk" %}

{% set tr = {
  id: {
    title: 'Atur Ulang Kata Sandi',
    intro: 'Masukkan kata sandi baru untuk akun Anda.',
    newPassword: 'Kata Sandi Baru',
    passwordHint: 'Minimal 10 karakter, mengandung huruf dan angka.',
    submit: 'Simpan Kata Sandi',
    backLink: 'Kembali ke halaman masuk'
  },
  en: {
    title: 'Reset Your Password',
    intro: 'Enter a new password for your account.',
    newPassword: 'New Password',
    passwordHint: 'At least 10 characters, containing letters and digits.',
    submit: 'Save Password',
    backLink: 'Back to login'
  }
} %}
{% set t = tr[locale] or tr.id %}

{% block title %}{{ t.title }} | PT Buana Megah{% endblock %}

{% block content %}
<section class="auth-form">
  <h1>{{ t.title }}</h1>
  <p>{{ t.intro }}</p>

  {% if generalError %}
    <div class="alert alert-error" role="alert">{{ generalError }}</div>
  {% endif %}

  <form method="post" action="/{{ locale }}/password/reset/{{ token }}" novalidate>
    <div class="field">
      <label for="newPassword">{{ t.newPassword }}</label>
      <input type="password"
             id="newPassword"
             name="newPassword"
             autocomplete="new-password"
             required
             minlength="10"
             maxlength="128">
      <small class="hint">{{ t.passwordHint }}</small>
      {% if errors.newPassword %}
        <ul class="field-errors">
          {% for msg in errors.newPassword %}<li>{{ msg }}</li>{% endfor %}
        </ul>
      {% endif %}
    </div>

    <button type="submit" class="btn btn-primary">{{ t.submit }}</button>
  </form>

  <p class="auth-form-footer">
    <a href="/{{ locale }}/login">{{ t.backLink }}</a>
  </p>
</section>
{% endblock %}
