{# Email verification "invalid or expired" page (task 9.3).
   Validates: Requirement 3.4 — generic message rendered for ANY token
   miss (missing, malformed, expired, already used). The page does NOT
   reveal which case it is, and offers a link to the resend form so a
   well-meaning visitor whose link expired can request a fresh one.

   Inputs:
     - locale  : 'id' | 'en'
     - cspNonce: string
#}
{% extends "layouts/public.njk" %}

{% set tr = {
  id: {
    title: 'Tautan Verifikasi Tidak Berlaku',
    body: 'Tautan verifikasi yang Anda gunakan tidak valid atau sudah kedaluwarsa. Anda dapat meminta tautan baru dengan memasukkan email yang Anda daftarkan.',
    resendCta: 'Kirim ulang email verifikasi',
    backLink: 'Kembali ke beranda'
  },
  en: {
    title: 'Verification Link Invalid',
    body: 'The verification link you used is invalid or has expired. You can request a new one by entering the email you registered with.',
    resendCta: 'Resend verification email',
    backLink: 'Back to home'
  }
} %}
{% set t = tr[locale] or tr.id %}

{% block title %}{{ t.title }} | PT Buana Megah{% endblock %}

{% block content %}
<section class="auth-error">
  <h1>{{ t.title }}</h1>
  <p>{{ t.body }}</p>
  <p>
    <a class="btn btn-primary" href="/{{ locale }}/verify/resend">{{ t.resendCta }}</a>
  </p>
  <p><a href="/{{ locale }}/">{{ t.backLink }}</a></p>
</section>
{% endblock %}
