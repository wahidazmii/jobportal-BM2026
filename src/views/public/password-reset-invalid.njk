{# Generic invalid / expired reset link page (task 11.2).
   Validates: Requirement 3.8 — Same page rendered when the token is
   structurally invalid, expired, or already consumed, so an attacker
   cannot enumerate token states.

   Inputs:
     - locale  : 'id' | 'en'
#}
{% extends "layouts/public.njk" %}

{% set tr = {
  id: {
    title: 'Tautan Tidak Valid',
    body: 'Tautan reset kata sandi ini tidak valid atau telah kedaluwarsa. Silakan ajukan permintaan reset baru.',
    requestLink: 'Ajukan reset kata sandi',
    loginLink: 'Kembali ke halaman masuk'
  },
  en: {
    title: 'Invalid or Expired Link',
    body: 'This password reset link is invalid or has expired. Please request a new reset.',
    requestLink: 'Request a new reset',
    loginLink: 'Back to login'
  }
} %}
{% set t = tr[locale] or tr.id %}

{% block title %}{{ t.title }} | PT Buana Megah{% endblock %}

{% block content %}
<section class="auth-error">
  <h1>{{ t.title }}</h1>
  <p>{{ t.body }}</p>
  <p>
    <a href="/{{ locale }}/password/reset">{{ t.requestLink }}</a>
    &middot;
    <a href="/{{ locale }}/login">{{ t.loginLink }}</a>
  </p>
</section>
{% endblock %}
