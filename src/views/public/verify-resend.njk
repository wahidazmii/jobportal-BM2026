{# Resend verification email form (task 9.3).
   Validates: Requirements 3.4, 14.1 — the form requires hCaptcha and is
   rate-limited at 3 requests per IP per hour. The submit handler
   responds with a generic "if a pending account exists" page so the
   form cannot be used to enumerate registered emails.

   Inputs:
     - locale          : 'id' | 'en'
     - form            : { email }                 (sticky value)
     - errors          : Record<string, string[]>  (zod fieldErrors)
     - generalError    : string | null             (top-level message)
     - hcaptchaSiteKey : string | null             (null → no widget)
     - cspNonce        : string
#}
{% extends "layouts/public.njk" %}

{% set tr = {
  id: {
    title: 'Kirim Ulang Email Verifikasi',
    intro: 'Masukkan email yang Anda daftarkan. Jika akun masih menunggu verifikasi, kami akan mengirim ulang tautan baru yang berlaku 24 jam.',
    email: 'Email',
    submit: 'Kirim Tautan',
    backLink: 'Kembali ke beranda'
  },
  en: {
    title: 'Resend Verification Email',
    intro: 'Enter the email you registered with. If the account is still pending verification, we will send a fresh link valid for 24 hours.',
    email: 'Email',
    submit: 'Send Link',
    backLink: 'Back to home'
  }
} %}
{% set t = tr[locale] or tr.id %}

{% block title %}{{ t.title }} | PT Buana Megah{% endblock %}

{% block head %}
  {% if hcaptchaSiteKey %}
    <link rel="preconnect" href="https://hcaptcha.com">
    <link rel="preconnect" href="https://newassets.hcaptcha.com">
    <script src="https://hcaptcha.com/1/api.js" async defer{% if cspNonce %} nonce="{{ cspNonce }}"{% endif %}></script>
  {% endif %}
{% endblock %}

{% block content %}
<section class="auth-form">
  <h1>{{ t.title }}</h1>
  <p>{{ t.intro }}</p>

  {% if generalError %}
    <div class="alert alert-error" role="alert">{{ generalError }}</div>
  {% endif %}

  <form method="post" action="/{{ locale }}/verify/resend" novalidate>
    <div class="field">
      <label for="email">{{ t.email }}</label>
      <input type="email"
             id="email"
             name="email"
             autocomplete="email"
             required
             maxlength="254"
             value="{{ form.email | default('') }}">
      {% if errors.email %}
        <ul class="field-errors">
          {% for msg in errors.email %}<li>{{ msg }}</li>{% endfor %}
        </ul>
      {% endif %}
    </div>

    {% if hcaptchaSiteKey %}
      <div class="field">
        <div class="h-captcha" data-sitekey="{{ hcaptchaSiteKey }}"></div>
      </div>
    {% else %}
      {# Dev/test mode: no live captcha. The schema still requires a non-empty
         token so we provide a fixed placeholder that satisfies the form. #}
      <input type="hidden" name="h-captcha-response" value="dev-no-captcha">
    {% endif %}
    {% if errors.captchaToken %}
      <ul class="field-errors">
        {% for msg in errors.captchaToken %}<li>{{ msg }}</li>{% endfor %}
      </ul>
    {% endif %}

    <button type="submit" class="btn btn-primary">{{ t.submit }}</button>
  </form>

  <p class="auth-form-footer">
    <a href="/{{ locale }}/">{{ t.backLink }}</a>
  </p>
</section>
{% endblock %}
