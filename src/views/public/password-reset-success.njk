{# Password reset success page (task 11.2).
   Validates: Requirements 3.8, 3.10 — confirmation that the password has
   been changed and all sessions revoked, with a CTA back to the login form.

   Inputs:
     - locale  : 'id' | 'en'
#}
{% extends "layouts/public.njk" %}

{% set tr = {
  id: {
    title: 'Kata Sandi Diperbarui',
    body: 'Kata sandi Anda telah diperbarui. Semua sesi aktif telah keluar — silakan masuk kembali dengan kata sandi baru.',
    loginLink: 'Masuk sekarang'
  },
  en: {
    title: 'Password Updated',
    body: 'Your password has been updated. All existing sessions have been signed out — please log in with your new password.',
    loginLink: 'Log in now'
  }
} %}
{% set t = tr[locale] or tr.id %}

{% block title %}{{ t.title }} | PT Buana Megah{% endblock %}

{% block content %}
<section class="auth-success">
  <h1>{{ t.title }}</h1>
  <p>{{ t.body }}</p>
  <p><a href="/{{ locale }}/login">{{ t.loginLink }}</a></p>
</section>
{% endblock %}
