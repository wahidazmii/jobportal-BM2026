<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Job Alert — PT Buana Megah</title>
  </head>
  <body style="margin:0;padding:0;background:#f4f5f7;font-family:Arial,Helvetica,sans-serif;color:#1f2933;">
    <div style="max-width:600px;margin:0 auto;padding:24px;">
      <h1 style="font-size:20px;margin:0 0 16px;">Lowongan baru untuk Anda</h1>
      <p style="font-size:14px;line-height:1.5;margin:0 0 16px;">
        Halo {{ applicant.name }},
      </p>
      <p style="font-size:14px;line-height:1.5;margin:0 0 20px;">
        {% if count == 1 %}
          Ada 1 lowongan baru yang cocok dengan Job Alert Anda.
        {% else %}
          Ada {{ count }} lowongan baru yang cocok dengan Job Alert Anda.
        {% endif %}
      </p>

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
        {% for job in jobs %}
        <tr>
          <td style="padding:12px 0;border-bottom:1px solid #e4e7eb;">
            <a href="{{ job.url }}" style="font-size:16px;font-weight:bold;color:#2563eb;text-decoration:none;">{{ job.title }}</a>
            <div style="font-size:13px;color:#52606d;margin-top:4px;">{{ job.location }}</div>
          </td>
        </tr>
        {% endfor %}
      </table>

      <p style="font-size:12px;color:#7b8794;line-height:1.5;margin:24px 0 0;">
        Anda menerima email ini karena memiliki Job Alert aktif di portal karier
        PT Buana Megah. Kelola atau hapus Job Alert Anda di halaman Job Alert pada
        akun Anda.
      </p>
    </div>
  </body>
</html>
