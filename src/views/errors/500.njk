    a  {
      display: inline-block;
      padding: 0.5rem 1.25rem;
      background: #2563eb;
      color: #fff;
      border-radius: 0.375rem;
      text-decoration: none;
    }
    a:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <div class="container">
    <h1>500</h1>
    <h2>Terjadi Kesalahan Server</h2>
